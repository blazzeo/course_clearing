# API
DATABASE_URL=postgres://clearing:clearing@postgres:5432/clearing
FRONTEND_ORIGIN=https://localhost:3000
RUST_LOG=info

# Solana
SOLANA_RPC_URL=http://localnet:8899
SOLANA_WS_URL=ws://localnet:8900

# Anchor bootstrap wallet for demo (JSON array secret key)
# Example: [12,34,...]
ADMIN_SECRET_KEY_JSON=

# Optional: comma-separated wallets to fund in init.ts
AIRDROP_ADDRESSES=
AIRDROP_SOL=2

# Must match ADMIN_SECRET_KEY_JSON public key
ADMIN_PUBKEY=
