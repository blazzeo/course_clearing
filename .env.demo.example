# Скопируйте в `.env.demo` (см. Makefile: `ENV_FILE ?= .env.demo`) или в корневой `.env` для локального API.
# Не коммитьте файлы с реальными ключами.

# ----- API (Rust, `api/src/main.rs`, `dotenv` читает `.env` из текущей директории при запуске) -----
PORT=3001
DATABASE_URL=postgres://clearing:clearing@postgres:5432/clearing
# Для API на хосте без Docker замените хост: postgres → localhost
FRONTEND_ORIGIN=https://localhost:3000
# Локальный Vite без nginx: http://localhost:5173
RUST_LOG=info

# Solana RPC/WS (индексер и воркер)
SOLANA_RPC_URL=http://localnet:8899
SOLANA_WS_URL=ws://localnet:8900
# Вне Docker (локальный test-validator):
# SOLANA_RPC_URL=http://127.0.0.1:8899
# SOLANA_WS_URL=ws://127.0.0.1:8900

# Публичный ключ админа для подписанных запросов к API (обязательно)
ADMIN_PUBKEY=

# Версия/метка сборки в JSON сессии клиринга (необязательно, по умолчанию в коде — dev)
BUILD_SHA=dev

# ----- Docker: сервис `anchor-deploy` (кошелёк для anchor deploy / migrate) -----
# JSON-массив байт секретного ключа (как в solana-keygen json)
ADMIN_SECRET_KEY_JSON=

# ----- `clearing_solana/scripts/init.ts` (локально можно вместо JSON) -----
# Строка приватного ключа (формат как у solana-cli), опционально
ADMIN_PRIVATE_KEY=

AIRDROP_ADDRESSES=
AIRDROP_SOL=2

# ----- Frontend (Vite): при `yarn dev` в каталоге `frontend/` положите копию в `frontend/.env` -----
VITE_API_URL=http://localhost:3001/api
VITE_SOLANA_RPC_URL=http://localhost:8899
# Зарезервировано в типах; если не задано — берётся из IDL
VITE_PROGRAM_ID=
